    "Location access allows QR Unveil to provide geo-based features when scanning location QR codes. This is optional but recommended for full functionality." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يتيح الوصول إلى الموقع لـ QR Unveil توفير ميزات تعتمد على الموقع الجغرافي عند مسح رموز QR للمواقع. هذا اختياري ولكنه موصى به للحصول على وظائف كاملة."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'accés a la ubicació permet a QR Unveil proporcionar funcions basades en geolocalització quan escaneja codis QR de localització. Això és opcional però es recomana per a una funcionalitat completa."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Placeringsadgang giver QR Unveil mulighed for at tilbyde geografibaserede funktioner, når du scanner placerings-QR-koder. Dette er valgfrit, men anbefales for fuld funktionalitet."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Standortzugriff ermöglicht es QR Unveil, standortbasierte Funktionen beim Scannen von Standort-QR-Codes bereitzustellen. Dies ist optional, wird jedoch für die volle Funktionalität empfohlen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Η πρόσβαση τοποθεσίας επιτρέπει στο QR Unveil να παρέχει λειτουργίες με βάση τη γεωγραφική θέση κατά τη σάρωση κωδικών QR τοποθεσίας. Αυτό είναι προαιρετικό αλλά συνιστάται για πλήρη λειτουργικότητα."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El acceso a la ubicación permite a QR Unveil proporcionar funciones geográficas al escanear códigos QR de ubicación. Esto es opcional pero recomendado para una funcionalidad completa."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El acceso a la ubicación permite a QR Unveil proporcionar funciones basadas en la geolocalización al escanear códigos QR de ubicación. Esto es opcional pero recomendado para una funcionalidad completa."
          }
        },
        "es-US" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El acceso a la ubicación permite a QR Unveil proporcionar funciones geográficas al escanear códigos QR de ubicación. Esto es opcional pero recomendado para una funcionalidad completa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'accès à la localisation permet à QR Unveil de fournir des fonctionnalités géolocalisées lors du scan de codes QR de lieu. Cette option est facultative mais recommandée pour une fonctionnalité complète."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'accès à la localisation permet à QR Unveil de fournir des fonctionnalités géolocalisées lors de la numérisation des codes QR de lieu. C'est optionnel mais recommandé pour une fonctionnalité complète."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'accesso alla posizione consente a QR Unveil di fornire funzionalità basate sulla geolocalizzazione durante la scansione dei codici QR di posizione. Questo è opzionale ma consigliato per la piena funzionalità."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "位置情報へのアクセスを許可すると、QR Unveilは位置情報QRコードをスキャンする際に地理ベースの機能を提供できます。これはオプションですが、すべての機能を利用するためにお勧めします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "위치 접근을 허용하면 QR Unveil이 위치 QR 코드를 스캔할 때 지리 기반 기능을 제공할 수 있습니다. 이는 선택 사항이지만 완전한 기능을 위해 권장됩니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O acesso à localização permite que o QR Unveil forneça recursos baseados em geolocalização ao escanear códigos QR de localização. Isso é opcional, mas recomendado para funcionalidade completa."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O acesso à localização permite ao QR Unveil fornecer funcionalidades baseadas em localização ao ler códigos QR de locais. Esta opção é opcional, mas recomendada para funcionalidade completa."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Доступ к местоположению позволяет QR Unveil предоставлять геолокационные функции при сканировании QR-кодов с местоположением. Это необязательно, но рекомендуется для полной функциональности."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Platsåtkomst låter QR Unveil tillhandahålla platsbaserade funktioner vid skanning av QR-koder för platser. Detta är valfritt men rekommenderas för full funktionalitet."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Konum erişimi, QR Unveil'in konum QR kodlarını tararken coğrafi tabanlı özellikler sunmasına olanak tanır. Bu isteğe bağlıdır ancak tam işlevsellik için önerilir."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Доступ до місцезнаходження дозволяє QR Unveil надавати геолокаційні функції при скануванні QR-кодів із місцезнаходженням. Це необов'язково, але рекомендується для повної функціональності."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "位置访问允许 QR Unveil 在扫描位置相关二维码时提供基于地理位置的功能。这是可选的，但建议启用以获得完整功能。"
          }
        }
      }
    },
