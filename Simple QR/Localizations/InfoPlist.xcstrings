          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QR Unveil은 QR 코드 이미지를 사진 라이브러리의 전용 앨범에 저장합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
