    "NSCameraUsageDescription" : {
      "comment" : "Privacy - Camera Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يحتاج QR Unveil إلى الوصول إلى الكاميرا لمسح رموز QR"
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QR Unveil necessita accés a la càmera per escanejar codis QR"
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QR Unveil skal have adgang til kameraet for at scanne QR-koder"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QR Unveil benötigt Kamerazugriff zum Scannen von QR-Codes"
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Το QR Unveil χρειάζεται πρόσβαση στην κάμερα για σάρωση κωδικών QR"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "QR Unveil needs camera access to scan QR codes"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QR Unveil necesita acceso a la cámara para escanear códigos QR"
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QR Unveil necesita acceso a la cámara para escanear códigos QR"
          }
        },
        "es-US" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QR Unveil necesita acceso a la cámara para escanear códigos QR"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QR Unveil a besoin d'accéder à l'appareil photo pour scanner les codes QR"
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QR Unveil a besoin d'accéder à la caméra pour numériser les codes QR"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QR Unveil ha bisogno dell'accesso alla fotocamera per scansionare i codici QR"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QR Unveilは、QRコードをスキャンするためにカメラへのアクセスが必要です"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QR Unveil은 QR 코드를 스캔하기 위해 카메라 접근 권한이 필요합니다"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O QR Unveil precisa de acesso à câmera para escanear códigos QR"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QR Unveil necessita de acesso à câmara para ler códigos QR"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QR Unveil требуется доступ к камере для сканирования QR-кодов"
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QR Unveil behöver kameraåtkomst för att skanna QR-koder"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QR Unveil, QR kodlarını taramak için kamera erişimine ihtiyaç duyar"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QR Unveil потребує доступ до камери для сканування QR-кодів"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QR Unveil 需要相机权限以扫描二维码"
          }
        }
      }
    },
    "NSLocationWhenInUseUsageDescription" : {
      "comment" : "Privacy - Location When In Use Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الوصول إلى الموقع يسمح لـ QR Unveil بتسجيل المكان الذي قمت فيه بمسح الرموز. تظل هذه البيانات على جهازك وحساب iCloud الشخصي الخاص بك فقط."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'accés a la ubicació permet a QR Unveil registrar on has escanejat els codis. Aquestes dades es queden només al teu dispositiu i al teu compte personal d'iCloud.\r\n\r\n"
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adgang til placering gør det muligt for QR Unveil at registrere, hvor du har scannet koder. Disse data forbliver kun på din enhed og din personlige iCloud-konto."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Standortzugriff erlaubt es QR Unveil, den Ort zu speichern, an dem Sie Codes gescannt haben. Diese Daten bleiben ausschließlich auf Ihrem Gerät und Ihrem persönlichen iCloud-Konto."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Η πρόσβαση στη θέση επιτρέπει στο QR Unveil να καταγράφει πού σαρώσατε κωδικούς. Αυτά τα δεδομένα παραμένουν μόνο στη συσκευή σας και στον προσωπικό σας λογαριασμό iCloud."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Location access allows QR Unveil to record where you scanned codes. This data stays on your device and your personal iCloud account only."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El acceso a la ubicación permite a QR Unveil registrar dónde escaneaste los códigos. Estos datos permanecen solo en tu dispositivo y en tu cuenta personal de iCloud."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El acceso a la ubicación permite a QR Unveil registrar dónde escaneaste los códigos. Estos datos permanecen solo en tu dispositivo y en tu cuenta personal de iCloud."
          }
        },
        "es-US" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El acceso a la ubicación permite a QR Unveil registrar dónde escaneaste los códigos. Estos datos permanecen solo en tu dispositivo y en tu cuenta personal de iCloud."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'accès à la localisation permet à QR Unveil d'enregistrer l'endroit où vous avez scanné les codes. Ces données restent uniquement sur votre appareil et votre compte iCloud personnel."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L’accès à la localisation permet à QR Unveil d’enregistrer où vous avez numérisé les codes. Ces données restent uniquement sur votre appareil et votre compte iCloud personnel."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'accesso alla posizione consente a QR Unveil di registrare dove hai scansionato i codici. Questi dati rimangono solo sul tuo dispositivo e sul tuo account iCloud personale"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "位置情報へのアクセスにより、QR Unveil はコードをスキャンした場所を記録できます。このデータはデバイスと個人の iCloud アカウントにのみ保存されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "위치 액세스를 통해 QR Unveil은 코드를 스캔한 위치를 기록할 수 있습니다. 이 데이터는 귀하의 기기와 개인 iCloud 계정에만 저장됩니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O acesso à localização permite que o QR Unveil registre onde você escaneou os códigos. Esses dados permanecem apenas no seu dispositivo e na sua conta pessoal do iCloud."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O acesso à localização permite que o QR Unveil registe onde escaneou os códigos. Estes dados permanecem apenas no seu dispositivo e na sua conta pessoal do iCloud."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Доступ к местоположению позволяет QR Unveil записывать, где вы сканировали коды. Эти данные остаются только на вашем устройстве и в вашем личном аккаунте iCloud."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Åtkomst till platsdata gör det möjligt för QR Unveil att registrera var du skannade koder. Dessa data stannar endast på din enhet och ditt personliga iCloud-konto."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Konum erişimi, QR Unveil'in kodları nerede taradığınızı kaydetmesine olanak tanır. Bu veriler yalnızca cihazınızda ve kişisel iCloud hesabınızda kalır."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Доступ до місцезнаходження дозволяє QR Unveil записувати, де ви сканували коди. Ці дані залишаються лише на вашому пристрої та у вашому особистому обліковому записі iCloud."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "位置访问权限允许 QR Unveil 记录您扫描代码的位置。此数据仅保留在您的设备和个人 iCloud 账户中。"
          }
        }
      }
    },
    "NSPhotoLibraryAddUsageDescription" : {
      "comment" : "Privacy - Photo Library Additions Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يحفظ QR Unveil صور رموز QR في ألبوم مخصص في مكتبة الصور الخاصة بك."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QR Unveil desa les imatges de codis QR en un àlbum dedicat a la teva biblioteca de fotos."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QR Unveil gemmer QR-kodebilleder i et dedikeret album i dit fotobibliotek."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QR Unveil speichert QR-Code-Bilder in einem speziellen Album in Ihrer Fotobibliothek."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Το QR Unveil αποθηκεύει εικόνες κωδικών QR σε ένα ειδικό άλμπουμ στη βιβλιοθήκη φωτογραφιών σας."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "QR Unveil saves QR code images to a dedicated album in your photo library."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QR Unveil guarda las imágenes de códigos QR en un álbum específico en tu biblioteca de fotos."
          }
        },
        "es-419" : {
          "stringUnit" : {
